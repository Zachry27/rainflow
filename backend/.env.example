# RainFlow Backend — Konfigurasi
# Copy file ini menjadi .env dan sesuaikan nilainya

# ============ Konfigurasi Server ============
HOST=0.0.0.0
PORT=9564
DEBUG=false

# ============ Keamanan API ============
API_KEY=rainflow-secret

# ============ Verifikasi Cloudflare ============
CF_CLEARANCE=

# ============ Konfigurasi SSO ============
SSO_FILE=key.txt
SSO_ROTATION_STRATEGY=hybrid
SSO_DAILY_LIMIT=50

# ============ Penyimpanan Media ============
VIDEOS_DIR=data/videos

# ============ Konfigurasi Generate ============
DEFAULT_ASPECT_RATIO=16:9
GENERATION_TIMEOUT=180
