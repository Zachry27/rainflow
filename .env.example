# ============================================================
# RainFlow — Environment Config
# Copy file ini menjadi .env lalu sesuaikan nilainya
# File .env TIDAK akan ikut ter-push ke GitHub (sudah gitignored)
# ============================================================

# === GrokPI Backend ===
# URL dari server GrokPI. Kosongkan saja agar otomatis menggunakan Proxy internal.
# Jika dikosongkan, aplikasi bisa diakses dari HP/PC lain tanpa error koneksi.
VITE_GROKPI_API_URL=
VITE_GROKPI_API_KEY=your_api_key_here

# === Google Drive OAuth ===
# Client ID dari Google Cloud Console
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# === FFmpeg ===
# Path FOLDER tempat ffmpeg.exe & ffprobe.exe berada (tanpa nama file)
# Contoh lokal Windows    : FFMPEG_DIR=D:\APLIKASI\BenAlus
# Contoh RDP/VPS Linux    : FFMPEG_DIR=/usr/bin
# Jika ffmpeg sudah ada di PATH sistem, baris ini bisa dikosongkan
FFMPEG_DIR=C:\path\to\ffmpeg\folder
